# This repository contains a FastAPI backend and a Vite/React frontend.
# Copy the relevant variables into your local env files.
#
# Backend: copy to `.env`
# Frontend: copy to `.env.local` (Vite ignores `.env.local` in git)

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=https://your-backend.railway.app

# ── Backend ────────────────────────────────────────────────────────────────────

# Generate a strong secret:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Comma-separated list of allowed frontend origins (no trailing slashes)
# Example for prod: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SQLite (default) or Postgres for production:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./cafe.db
